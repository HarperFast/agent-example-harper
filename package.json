{
  "name": "agent-example-harper",
  "version": "1.0.0",
  "description": "A conversational AI agent with persistent memory, built on Harper and Claude",
  "type": "module",
  "engines": {
    "harper": "^5.1",
    "node": "^22.18.0 || >=24.0.0"
  },
  "scripts": {
    "start": "npx -y dotenv-cli -e .env -o -- harper run .",
    "dev": "npx -y dotenv-cli -e .env -o -- harper dev .",
    "login": "node login.js",
    "deploy": "npx -y dotenv-cli -- harper deploy . restart=rolling replicated=true",
    "test:integration": "harper-integration-test-run 'integrationTests/**/*.test.ts'"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@anthropic-ai/vertex-sdk": "^0.15.0",
    "graphql": "^16.8.1",
    "harper": "^5.1.9"
  },
  "devDependencies": {
    "@harperfast/integration-testing": "^0.3.1",
    "@types/node": "^22.19.19"
  }
}
